{
  "expo": {
    "name": "Birthdayz",
    "slug": "birthdayz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "birthdayz",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF5EB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.birthdayz.mobile",
      "infoPlist": {
        "NSContactsUsageDescription": "Birthdayz uses your contacts to find friends with saved birthdays so you never forget."
      }
    },
    "android": {
      "package": "app.birthdayz.mobile",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFF5EB"
      },
      "edgeToEdgeEnabled": false,
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.616383775014-tvt60qm0jkkftnu93tdlhhtea2noe4j5"
        }
      ],
      "expo-localization",
      "expo-font",
      [
        "expo-contacts",
        {
          "contactsPermission": "Birthdayz uses your contacts to find friends with saved birthdays."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#E8756A"
        }
      ],
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "880f6378-94a7-4a86-a792-4b624a05de78"
      }
    },
    "owner": "vincentjac88"
  }
}
