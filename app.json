{
  "expo": {
    "name": "Birthdayz",
    "slug": "birthdayz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "birthdayz",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF5EB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.birthdayz.mobile",
      "infoPlist": {
        "NSContactsUsageDescription": "Birthdayz uses your contacts to find friends with saved birthdays so you never forget."
      }
    },
    "android": {
      "package": "app.birthdayz.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFF5EB"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["android.permission.READ_CONTACTS"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.616383775014-tvt60qm0jkkftnu93tdlhhtea2noe4j5"
        }
      ],
      "expo-localization",
      "expo-font",
      [
        "expo-contacts",
        {
          "contactsPermission": "Birthdayz uses your contacts to find friends with saved birthdays."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#E8756A"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
